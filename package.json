{
  "name": "serein-tcc-act",
  "version": "1.0.0",
  "description": "Serein TCC·ACT - PWA de soutien émotionnel TCC/ACT, wrappée avec Capacitor pour iOS et Android.",
  "license": "MIT",
  "author": "César Broche Aguilar",
  "type": "module",
  "scripts": {
    "build:web": "node scripts/build-www.mjs",
    "test": "node --test \"tests/*.test.js\"",
    "sync": "npm run build:web && cap sync",
    "bump:android": "node scripts/bump-android-version.mjs",
    "release:android": "npm run build:web && npx cap sync android && npm run bump:android",
    "open:android": "cap open android",
    "open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.3.3",
    "@capacitor/dialog": "^8.0.1",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/local-notifications": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/text-zoom": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5"
  }
}
